{
    "expo":  {
                 "name":  "HoBo POS",
                 "slug":  "hobo-pos",
                 "version":  "1.0.0",
                 "sdkVersion":  "54.0.0",
                 "orientation":  "portrait",
                 "icon":  "./assets/icon.png",
                 "userInterfaceStyle":  "dark",
                 "splash":  {
                                "resizeMode":  "contain",
                                "backgroundColor":  "#1a1a1a"
                            },
                 "assetBundlePatterns":  [
                                             "**/*"
                                         ],
                 "ios":  {
                             "supportsTablet":  true,
                             "bundleIdentifier":  "com.hobopos.app",
                             "infoPlist":  {
                                               "NSCameraUsageDescription":  "HoBo POS needs camera access to scan QR codes and take photos.",
                                               "NSPhotoLibraryUsageDescription":  "HoBo POS needs photo library access to select images."
                                           }
                         },
                 "android":  {
                                 "adaptiveIcon":  {
                                                      "backgroundColor":  "#1a1a1a"
                                                  },
                                 "package":  "com.hobopos.app",
                                 "permissions":  [
                                                     "CAMERA",
                                                     "READ_EXTERNAL_STORAGE",
                                                     "WRITE_EXTERNAL_STORAGE"
                                                 ]
                             },
                 "web":  {

                         },
                 "plugins":  [
                                 [
                                     "expo-camera",
                                     {
                                         "cameraPermission":  "HoBo POS needs camera access to scan QR codes and take photos."
                                     }
                                 ],
                                 "expo-asset"
                             ],
                 "extra":  {
                               "apiUrl":  "http://172.20.176.1:8000/api",
                               "localIp":  "172.20.176.1",
                               "eas":  {
                                           "projectId":  "hobo-pos-expo"
                                       }
                           }
             }
}

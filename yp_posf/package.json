{
  "name": "yp_posf",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-favicon.js && vite build",
    "preview": "vite preview",
    "format": "prettier --write src/",
    "tailwind-init": "tailwindcss init -p",
    "screenshots": "playwright test e2e/screenshots-for-marketing.spec.js --project=chromium",
    "test:e2e:demo": "node scripts/run-e2e-demo.js",
    "test:e2e:browser-demo": "playwright test e2e/browser_demo_report.spec.js --project=chromium",
    "test:e2e:browser-demo:headed": "playwright test e2e/browser_demo_report.spec.js --project=chromium --headed",
    "test:stress": "playwright test e2e/e2e_stress_test.spec.js --project=chromium",
    "simulate": "node simulate.js",
    "simulate:full": "node run-simulation.js",
    "simulate:machinery": "node simulate_machinery_shop.js",
    "simulate:machinery:full": "node run_machinery_sim.js",
    "cap:sync": "npm run build && npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "expo:start": "expo start",
    "expo:start:tunnel": "expo start --tunnel",
    "expo:start:offline": "EXPO_OFFLINE=1 expo start",
    "expo:android": "expo start --android",
    "expo:ios": "expo start --ios",
    "expo:web": "expo start --web"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/camera": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@tailwindcss/postcss": "4.0.7",
    "@types/react": "~19.1.10",
    "apexcharts": "^5.3.6",
    "axios": "^1.13.2",
    "dexie": "^4.3.0",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.12",
    "expo-camera": "~17.0.0",
    "expo-constants": "~18.0.0",
    "expo-network": "~8.0.8",
    "expo-status-bar": "~3.0.9",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.1",
    "lucide-vue-next": "^0.562.0",
    "pinia": "^3.0.4",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-webview": "13.15.0",
    "typescript": "^5.3.3",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3",
    "vue3-apexcharts": "^1.10.0"
  },
  "devDependencies": {
    "@fontsource-variable/inter": "^5.1.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "4.0.7",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitejs/plugin-vue-jsx": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "tailwindcss": "4.0.7",
    "vite": "^7.2.4",
    "vite-plugin-vue-devtools": "^8.0.5"
  }
}

# Production အတွက် ဤ File ကို .env အဖြစ် Copy ပြီး ပြင်ဆင်ပါ
# cp .env.example .env

# Django Secret Key (Production မှာ မဖြစ်မနေ သတ်မှတ်ပါ)
DJANGO_SECRET_KEY=your-secret-key-here

# Production
# DEBUG=False
# DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CORS_ALLOW_ALL=False

# Telegram Bot (new user registration notification)
TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
TELEGRAM_CHAT_ID=your-chat-id

# Google Sheets (append new registrations; optional)
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SHEETS_SHEET_NAME=Registrations
GOOGLE_SHEETS_CREDENTIALS_JSON=/path/to/service-account.json
